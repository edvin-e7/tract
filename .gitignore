# Go
/bin/
*.test
*.out

# Databases (WAL/SHM siblings included)
*.db
*.db-wal
*.db-shm

# Node / Vite
frontend/node_modules/
frontend/dist/

# Built frontend staged into the embed dir (regenerated by scripts/build.sh).
