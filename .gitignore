# OS / editor
.DS_Store
*.swp

# TS incremental build cache
frontend/*.tsbuildinfo

# Capacitor iOS shell: synced web assets + Xcode build output (regenerated by
# `npx cap sync ios` / xcodebuild). Same policy as korkort-app.
frontend/ios/App/App/public/
frontend/ios/App/build/
frontend/ios/DerivedData/
